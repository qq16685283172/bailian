9},{"nickname":"周晓更","points":29},{"nickname":"刘雪岭","points":29},{"nickname":"汪全华","points":28},{"nickname":"梁美华","points":28}],"monthlyRanking":[{"nickname":"弘历软件","points":30},{"nickname":"文国云","points":30},{"nickname":"骆伯辉","points":30},{"nickname":"霍书云","points":30},{"nickname":"杨陆军","points":30},{"nickname":"何鸿","points":30},{"nickname":"张务一","points":30},{"nickname":"沈志仙","points":30},{"nickname":"陈燕","points":30},{"nickname":"耿富强","points":30},{"nickname":"周龙云","points":30},{"nickname":"杨中秀","points":30},{"nickname":"刘发梅","points":30},{"nickname":"朱益红","points":29},{"nickname":"李志立","points":29},{"nickname":"沈人龙","points":29},{"nickname":"周晓更","points":29},{"nickname":"刘雪岭","points":29},{"nickname":"汪全华","points":28},{"nickname":"梁美华","points":28}],"cumulativeRanking":[{"nickname":"弘历软件","points":30},{"nickname":"文国云","points":30},{"nickname":"骆伯辉","points":30},{"nickname":"霍书云","points":30},{"nickname":"杨陆军","points":30},{"nickname":"何鸿","points":30},{"nickname":"张务一","points":30},{"nickname":"沈志仙","points":30},{"nickname":"陈燕","points":30},{"nickname":"耿富强","points":30},{"nickname":"周龙云","points":30},{"nickname":"杨中秀","points":30},{"nickname":"刘发梅","points":30},{"nickname":"朱益红","points":29},{"nickname":"李志立","points":29},{"nickname":"沈人龙","points":29},{"nickname":"周晓更","points":29},{"nickname":"刘雪岭","points":29},{"nickname":"汪全华","points":28},{"nickname":"梁美华","points":28}],"announcements":["数据更新至2026年6月第3周","恭喜 弘历软件 以 30 成长值领跑","今日直播：易学久会 10:00 / 财经壹眼 20:00"]};

var appData = null;
var currentUser = null;

function getLevel(gp){for(var i=LEVELS.length-1;i>=0;i--){if(gp>=LEVELS[i].min)return LEVELS[i];}return LEVELS[0];}
function getNextLevel(gp){for(var i=0;i<LEVELS.length;i++){if(gp<LEVELS[i].max)return LEVELS[i];}return null;}
function getLevelIndex(gp){for(var i=LEVELS.length-1;i>=0;i--){if(gp>=LEVELS[i].min)return i;}return 0;}
async function loadData(){appData=EMBEDDED_DATA;try{var r=await fetch('data.json?'+Date.now());if(r.ok){appData=await r.json();}}catch(e){}return true;}


function renderMascot(lvIdx){var con=document.createElement("div");con.className="aircraft-wrap";var curIdx=lvIdx;var imgDiv=document.createElement("div");imgDiv.className="aircraft-svg";var lb=document.createElement("button");lb.className="aircraft-btn l";lb.innerHTML="◀";lb.onclick=function(e){e.stopPropagation();curIdx=Math.max(0,curIdx-1);upd(curIdx);};var rb=document.createElement("button");rb.className="aircraft-btn r";rb.innerHTML="▶";rb.onclick=function(e){e.stopPropagation();curIdx=Math.min(6,curIdx+1);upd(curIdx);};var info=document.createElement("div");info.className="aircraft-info";var nameEl=document.createElement("div");nameEl.className="ac-name";var dots=document.createElement("div");dots.className="aircraft-dots";var tx=0;con.addEventListener("touchstart",function(e){tx=e.touches[0].clientX;});con.addEventListener("touchend",function(e){var d=tx-e.changedTouches[0].clientX;if(Math.abs(d)>30){curIdx=Math.max(0,Math.min(6,curIdx+(d>0?1:-1)));upd(curIdx);}});function upd(idx){curIdx=Math.max(0,Math.min(6,idx));imgDiv.innerHTML="<img src=\"lv"+(curIdx+1)+".png\" style=\"width:100%;height:100%;object-fit:contain\" alt=\"LV"+(curIdx+1)+"\">";lb.style.display=curIdx>0?"":"none";rb.style.display=curIdx<6?"":"none";var lv2=curIdx+1;var owned=curIdx<=lvIdx;nameEl.innerHTML="LV"+lv2+" "+LEVELS[curIdx].name+(owned?"":" <span class=\"lock\">🔒</span>");dots.innerHTML="";for(var i=0;i<7;i++){var d=document.createElement("span");d.className="aircraft-dot"+(i===curIdx?" active":"")+(i<=lvIdx?" unlocked":" locked");d.onclick=function(j){return function(){curIdx=j;upd(j)}}(i);dots.appendChild(d)}}con.appendChild(lb);con.appendChild(imgDiv);con.appendChild(rb);info.appendChild(nameEl);info.appendChild(dots);con.appendChild(info);upd(lvIdx);return con;}

function renderHome(){var gp=currentUser.growthPoints;var lvl=getLevel(gp);var idx=getLevelIndex(gp);var nxt=getNextLevel(gp);
document.getElementById("levelBadge").textContent="LV"+lvl.lv;document.getElementById("lvName").textContent=lvl.name;document.getElementById("gpCount").textContent=gp;
var wrap=document.getElementById("lobsterDisplay");wrap.innerHTML="";wrap.appendChild(renderMascot(idx));
if(nxt){var rng=nxt.max-nxt.min;var cur=gp-nxt.min;var pct=Math.min(Math.max(cur/rng*100,0),100);document.getElementById("progressBar").style.width=pct+"%";document.getElementById("nextLevelText").textContent="距离"+nxt.name+"还需"+(nxt.max-gp)+"成长值";document.getElementById("progressPercent").textContent=Math.round(pct)+"%";}
else{document.getElementById("progressBar").style.width="100%";document.getElementById("nextLevelText").textContent="已满级！传奇领航官";document.getElementById("progressPercent").textContent="MAX";}

var al=document.getElementById("announcementList");al.innerHTML="";if(appData.announcements){appData.announcements.forEach(function(a){var d=document.createElement("div");d.className="item";d.textContent=a;al.appendChild(d)});}}
function renderRecords(){var list=document.getElementById("recordsList");list.innerHTML="";if(!currentUser.records||currentUser.records.length===0){list.innerHTML='<div class="empty">暂无成长记录</div>';return}
var sorted=[].concat(currentUser.records).reverse();sorted.forEach(function(r){var d=document.createElement("div");d.className="record";d.innerHTML='<div class="r-left"><span class="r-date">'+r.date+'</span><span class="r-source">'+r.source+'</span></div><span class="r-points">+'+r.points+'</span>';list.appendChild(d)})}
function renderMap(){var c=document.getElementById("mapLevels");c.innerHTML="";var gp=currentUser.growthPoints;var curIdx=getLevelIndex(gp);
LEVELS.forEach(function(l,i){var d=document.createElement("div");d.className="mapLevel";if(i===curIdx)d.className+=" current";else if(gp>=l.max)d.className+=" reached";
var gpR=l.max===Infinity?(l.min+"+"):(l.min+"-"+(l.max-1));d.innerHTML='<div class="ml-head"><div><span class="ml-lv">LV'+l.lv+'</span> <span class="ml-name">'+l.name+'</span></div><span class="ml-badge'+(i===curIdx?' current-badge':'')+'">'+(i===curIdx?"当前":(gp>=l.max?"已达成":""))+'</span></div><div class="ml-desc">'+""+'</div><div class="ml-gp">成长值 '+gpR+'</div>';c.appendChild(d)})}
function renderRewards(){var uc=document.getElementById("rewardsUnclaimed");var cc=document.getElementById("rewardsClaimed");var lc=document.getElementById("rewardsLocked");uc.innerHTML="";cc.innerHTML="";lc.innerHTML="";
var gp=currentUser.growthPoints;var ca=currentUser.claimedRewards||[];var hu=false,hc=false,hl=false;
LEVELS.forEach(function(l,i){if(i===0)return;var id="lv"+l.lv;var isClaimed=ca.indexOf(id)!==-1;var isUnlocked=gp>=l.min;
var card=document.createElement("div");card.className="rewardCard";var st,stt,bc,bt,bd=false;
if(isClaimed){st="claimed";stt="已领取";bc="claimed";bt="已领取";bd=true;hc=true;}
else if(isUnlocked){st="unclaimed";stt="可领取";bc="unclaimed";bt="领取奖励";hu=true;}
else{st="locked";stt="LV"+l.lv+"解锁";bc="locked";bt="未解锁";bd=true;hl=true;}
card.innerHTML='<div class="rc-icon '+st+'">'+l.icon+'</div><div class="rc-body"><div class="rc-name">'+l.reward+'</div><div class="rc-condition">'+""+'LV'+l.lv+' '+l.name+'</div></div><button class="rc-btn '+bc+'"'+(bd?" disabled":"")+' onclick="claimReward(\''+id+'\')">'+bt+'</button>';
if(isClaimed)cc.appendChild(card);else if(isUnlocked)uc.appendChild(card);else lc.appendChild(card)});
if(!hu)uc.innerHTML='<div style="padding:16px;text-align:center;color:var(--text-lighter);font-size:13px;">暂无待领取的奖励</div>';
if(!hc)cc.innerHTML='<div style="padding:16px;text-align:center;color:var(--text-lighter);font-size:13px;">暂无已领取的奖励</div>';
if(!hl)lc.innerHTML='<div style="padding:16px;text-align:center;color:var(--text-lighter);font-size:13px;">所有奖励均已解锁</div>';}
function calculateRanking(type){var rankings=[];if(!appData.users||!appData.users[0]||!appData.users[0].records){if(type==="weekly")return appData.weeklyRanking||[];if(type==="monthly")return appData.monthlyRanking||[];return appData.cumulativeRanking||[];}var now=new Date();var cutoff=new Date(0);if(type==="weekly"){cutoff=new Date(now);var d=now.getDay();cutoff.setDate(now.getDate()-d+(d===0?-6:1));cutoff.setHours(0,0,0,0);}else if(type==="monthly"){cutoff=new Date(now.getFullYear(),now.getMonth(),1);}var ct=cutoff.getTime();appData.users.forEach(function(user){if(!user.records)return;var t=0;user.records.forEach(function(r){if(new Date(r.date).getTime()>=ct)t+=r.points;});if(t>0)rankings.push({nickname:user.nickname,id:user.id,points:t});});rankings=rankings.filter(function(r){return r.id!=="30017755";});rankings.sort(function(a,b){return b.points-a.points;});return rankings;}
function renderLeaderboard(type){var list=document.getElementById("lbList");list.innerHTML="";var data=calculateRanking(type);var mr=document.getElementById("myRankDisplay");if(currentUser&&appData.users){var idx=appData.users.findIndex(function(u){return u.id===currentUser.id});if(idx>=0){mr.style.display="flex";(currentUser.id==="30017755"?mr.querySelector(".mrRank").textContent="管理员"&&(mr.querySelector(".mrDesc").textContent="不参与排名"):mr.querySelector(".mrRank").textContent="#"+(idx+1)&&(mr.querySelector(".mrDesc").textContent="共 "+appData.users.length+" 人"));mr.querySelector(".mrPoints").textContent=currentUser.growthPoints+" 成长值"}else{mr.style.display="none"}}else{mr.style.display="none"}
if(data.length===0){list.innerHTML='<div class="lbEmpty">暂无排行数据</div>';return}
data.forEach(function(entry,i){var d=document.createElement("div");d.className="lbEntry";var rc="",icon;if(i===0){rc="gold";icon="🥇"}else if(i===1){rc="silver";icon="🥈"}else if(i===2){rc="bronze";icon="🥉"}else{icon="#"+(i+1)}
d.innerHTML='<span class="lb-rank '+rc+'">'+icon+'</span><span class="lb-name">'+entry.nickname+'</span><span class="lb-points">'+entry.points+'</span>';list.appendChild(d)})}
function claimReward(id){if(!currentUser.claimedRewards)currentUser.claimedRewards=[];if(currentUser.claimedRewards.indexOf(id)!==-1){showSnackbar("该奖励已领取过了");return}
currentUser.claimedRewards.push(id);renderRewards();showSnackbar("🎉 恭喜领取奖励成功！")}
function showSnackbar(msg){var sb=document.getElementById("snackbar");sb.textContent=msg;sb.style.display="block";setTimeout(function(){sb.style.display="none"},2500)}
var currentPage="pageHome";
function switchPage(pid){document.querySelectorAll(".page").forEach(function(p){p.classList.remove("active")});document.getElementById(pid).classList.add("active");
document.querySelectorAll(".tab").forEach(function(t){t.classList.remove("active")});var tb=document.querySelector('.tab[data-page="'+pid+'"]');if(tb)tb.classList.add("active");currentPage=pid}
async function init(){await loadData();
document.getElementById("loginBtn").addEventListener("click",doLogin);
document.getElementById("memberId").addEventListener("keydown",function(e){if(e.key==="Enter")doLogin()});
document.querySelectorAll(".tab").forEach(function(tab){tab.addEventListener("click",function(){switchPage(tab.dataset.page)})});
document.querySelectorAll(".tabJump").forEach(function(el){el.addEventListener("click",function(e){e.preventDefault();var pages=["pageHome","pageRecords","pageMap","pageRewards","pageLeaderboard","pageLearn"];switchPage(pages[parseInt(el.dataset.tab)])})});
document.querySelectorAll(".learnNow").forEach(function(el){el.addEventListener("click",function(e){e.preventDefault();switchPage("pageLearn")})});
document.querySelectorAll(".lbt").forEach(function(btn){btn.addEventListener("click",function(){document.querySelectorAll(".lbt").forEach(function(b){b.classList.remove("active")});btn.classList.add("active");renderLeaderboard(btn.dataset.lb)})});
document.getElementById("adminBtn").addEventListener("click",function(){enterAdmin()})}
function doLogin(){var id=document.getElementById("memberId").value.trim().toUpperCase();var err=document.getElementById("loginError");
if(!id){err.style.display="block";err.textContent="请输入精网号";return}
var user=appData.users.find(function(u){return u.id.toUpperCase()===id});
if(!user){err.style.display="block";err.textContent="未找到该精网号，请确认后重试";return}
err.style.display="none";currentUser=user;document.getElementById("adminBtn").style.display=user.id&&user.id.charAt(0)==="3"?"":"none";
document.getElementById("loginScreen").style.display="none";document.getElementById("app").style.display="block";
document.getElementById("userName").textContent=user.nickname;document.getElementById("userId").textContent="精网号: "+user.id;
renderHome();renderRecords();renderMap();renderRewards();renderLeaderboard("weekly")}
function enterAdmin(){document.getElementById("app").style.display="none";document.getElementById("adminPanel").style.display="block";document.getElementById("csvInput").value="";document.getElementById("adminStatus").className="adminStatus";document.getElementById("adminStatus").style.display="none";document.getElementById("adminPreview").innerHTML=""}
function exitAdmin(){document.getElementById("adminPanel").style.display="none";document.getElementById("app").style.display="block"}
function importCSV(){var raw=document.getElementById("csvInput").value.trim();var st=document.getElementById("adminStatus");var pv=document.getElementById("adminPreview");
if(!raw){st.className="adminStatus error";st.textContent="请先粘贴CSV数据";st.style.display="block";return}
var lines=raw.split("\n");var rows=[];for(var i=0;i<lines.length;i++){var line=lines[i].trim();if(!line)continue;var cols=line.split(",");if(cols.length<6)continue;rows.push(cols)}
if(rows.length===0){st.className="adminStatus error";st.textContent="未解析到有效数据";st.style.display="block";return}
var html="<table><thead><tr><th>精网号</th><th>昵称</th><th>成长值</th><th>日期</th><th>来源</th><th>点数</th></tr></thead><tbody>";
rows.forEach(function(r){html+="<tr><td>"+r[0]+"</td><td>"+r[1]+"</td><td>"+r[2]+"</td><td>"+r[3]+"</td><td>"+r[4]+"</td><td>"+r[5]+"</td></tr>"});html+="</tbody></table>";pv.innerHTML=html;
var umap={};var wp={};var mp={};var cp={};
rows.forEach(function(r){var id=r[0],nm=r[1],gp=parseInt(r[2])||0,dt=r[3],src=r[4],pts=parseInt(r[5])||1;
if(!umap[id]){umap[id]={id:id,nickname:nm,growthPoints:gp,records:[],claimedRewards:[]}}
umap[id].records.push({date:dt,source:src,points:pts});
cp[id]=(cp[id]||0)+pts;
var d=new Date(dt);var now=new Date();var ws=new Date(now);ws.setDate(now.getDate()-now.getDay());if(d>=ws)wp[id]=(wp[id]||0)+pts;
if(d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear())mp[id]=(mp[id]||0)+pts});
window._importedUsers=umap;window._weekPoints=wp;window._monthPoints=mp;window._cumPoints=cp;
st.className="adminStatus success";st.textContent="成功解析 "+rows.length+" 条记录，"+(Object.keys(umap).length)+" 个用户";st.style.display="block"}
function exportJSON(){if(!window._importedUsers){showSnackbar("请先导入CSV数据");return}
var users=Object.values(window._importedUsers);
function toRank(obj){return Object.entries(obj).map(function(e){return{nickname:(users.find(function(u){return u.id===e[0]})||{}).nickname||e[0],points:e[1]}}).sort(function(a,b){return b.points-a.points})}
var exportData={lastUpdated:new Date().toISOString().split("T")[0],users:users.map(function(u){return{id:u.id,nickname:u.nickname,growthPoints:u.growthPoints,records:u.records,claimedRewards:u.claimedRewards}}),weeklyRanking:toRank(window._weekPoints),monthlyRanking:toRank(window._monthPoints),cumulativeRanking:toRank(window._cumPoints),announcements:(appData&&appData.announcements)||[]};
var blob=new Blob([JSON.stringify(exportData,null,2)],{type:"application/json"});var url=URL.createObjectURL(blob);var a=document.createElement("a");a.href=url;a.download="data.json";document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);showSnackbar("data.json 已下载，请上传到服务器覆盖旧文件")}
function getDefaultData(){return{lastUpdated:"2026-06-23",users:[{id:"JH0001",nickname:"张先生",growthPoints:45,claimedRewards:["lv2"],records:[{date:"2026-06-20",source:"易学久会签到",points:1},{date:"2026-06-20",source:"易学久会观看≥20分钟",points:1},{date:"2026-06-20",source:"易学久会课堂互动",points:1},{date:"2026-06-21",source:"财经壹眼签到",points:1},{date:"2026-06-21",source:"财经壹眼观看≥20分钟",points:1},{date:"2026-06-22",source:"易学久会签到",points:1},{date:"2026-06-22",source:"易学久会观看≥20分钟",points:1},{date:"2026-06-22",source:"易学久会课堂互动",points:1},{date:"2026-06-23",source:"易学久会签到",points:1},{date:"2026-06-23",source:"易学久会观看≥20分钟",points:1}]},{id:"JH0002",nickname:"李阿姨",growthPoints:18,claimedRewards:[],records:[{date:"2026-06-20",source:"易学久会签到",points:1},{date:"2026-06-20",source:"易学久会观看≥20分钟",points:1},{date:"2026-06-21",source:"易学久会签到",points:1},{date:"2026-06-22",source:"财经壹眼签到",points:1},{date:"2026-06-22",source:"财经壹眼观看≥20分钟",points:1},{date:"2026-06-22",source:"财经壹眼课堂互动",points:1},{date:"2026-06-23",source:"易学久会签到",points:1}]}],weeklyRanking:[],monthlyRanking:[],cumulativeRanking:[],announcements:["欢迎来到百炼计划成长中心！"]}}
// URL parameter admin access
if(window.location.search.indexOf("admin")!==-1){setTimeout(function(){enterAdmin()},100)}
init();
</script></body></html>
